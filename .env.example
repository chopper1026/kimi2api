# 服务监听地址
HOST=127.0.0.1
PORT=8000
# 复制此文件为 .env 并填写管理控制台密码

# Kimi 认证 Token (可选，也可以启动后在 /admin 面板保存)
# 支持两种格式:
#
# 1. Refresh Token (推荐): 长期有效的 Token，服务会自动用它换取短期 access token 并定时刷新
#    从浏览器 Cookie 中获取，通常不以 eyJ 开头
#    KIMI_TOKEN=cpmt_xxxxx...
#
# 2. JWT Access Token: 短期 Token (以 eyJ 开头)，从浏览器开发者工具获取
#    有效期较短，过期后需要重新获取
#    KIMI_TOKEN=eyJhbGciOi...
#
KIMI_TOKEN=

# 可选: 自定义API基础URL (默认: https://www.kimi.com)
KIMI_API_BASE=https://www.kimi.com

# 可选: Kimi Web 出站请求语言偏好
KIMI_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9,en-US;q=0.8,en;q=0.7

# 可选: Kimi Web 出站请求并发和最小间隔
KIMI_MAX_CONCURRENCY=2
KIMI_MIN_REQUEST_INTERVAL=0.5

# 可选: 请求超时时间(秒)
TIMEOUT=120

# 可选: 默认模型
MODEL=kimi-k2.6

# 可选: 默认 API Key；不填时需先通过管理面板创建，否则 /v1/* 会拒绝访问
OPENAI_API_KEY=

# 管理控制台密码 (必填，用于访问 /admin 面板)
ADMIN_PASSWORD=your-admin-password

# 可选: Cookie 签名密钥，不设则自动生成并持久化到 data/.session_secret
SESSION_SECRET=

# 可选: 本地 HTTP 开发时设为 false (默认 true)
# SECURE_COOKIES=false

# 可选: 数据持久化目录 相对路径(默认 data)
DATA_DIR=data

# 可选: 管理面板时间显示时区
TIMEZONE=Asia/Shanghai

# 可选: Docker 容器系统时区，建议与 TIMEZONE 保持一致
TZ=Asia/Shanghai

# 可选: 请求日志保留最近多少条
REQUEST_LOG_RETENTION=1000

# 可选: 单条请求正文最大保存大小，支持 512KB、1MB、2MiB 等写法
REQUEST_LOG_BODY_LIMIT=1MB

# 开发模式热重载
# RELOAD=false
