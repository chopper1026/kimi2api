# Kimi API Configuration
# 复制此文件为 .env 并填入您的Kimi Token

# 您的Kimi JWT Token (以eyJ开头的Token，从浏览器开发者工具获取)
KIMI_TOKEN=your_kimi_jwt_token_here

# 可选: 自定义API基础URL (默认: https://www.kimi.com)
# KIMI_API_BASE=https://www.kimi.com

# 可选: 请求超时时间(秒)
# TIMEOUT=120

# 可选: 默认模型
# MODEL=kimi-k2

# OpenAI 兼容接口对外暴露使用的 API Key
OPENAI_API_KEY=sk-kimi2api

# OpenAI 兼容服务监听地址
HOST=127.0.0.1
PORT=8000

# 开发模式热重载
# RELOAD=false
